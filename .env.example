# PostgreSQL connection string — used by all tools via DATABASE_URL
DATABASE_URL=postgresql://nebula:changeme@postgres:5432/nebula_forge

# Flask secret key
SECRET_KEY=change-this-in-production

# AtomicLoop — Atomic Red Team API key (if applicable)
ATOMICLOOP_API_KEY=

# VulnForge — NVD API key for higher rate limits
NVD_API_KEY=

# Flask debug mode (set to 1 to enable)
FLASK_DEBUG=0
